  "security_property_columns": [
    "property_id",
    "title",
    "enforcement_terms",
    "assumptions",
    "limitations"
  ],
  "security_property_rows": [
    {
      "assumptions": "Trusted public keys are provisioned by the SAGA registration path.; The production-facing ML-DSA path must wrap a vetted external backend.; Toy LWE evidence is research wiring evidence, not a production PQ claim.",
      "enforcement_terms": "request_envelope_valid, pq_signature_valid, can_accept",
      "limitations": "This property does not claim confidentiality or full post-quantum transport security.; Compatibility paths outside strict runtime auth are excluded.",
      "property_id": "unforgeability",
      "title": "Unforgeability of Execution Capabilities"
    },
    {
      "assumptions": "Request envelopes are encoded with deterministic canonical JSON.; The receiver compares transport fields with the signed envelope before execution.",
      "enforcement_terms": "saga_token_valid, request_envelope_valid, pq_signature_valid, can_accept",
      "limitations": "The claim covers fields represented in the signed request envelope.",
      "property_id": "context_binding",
      "title": "Context Binding"
    },
    {
      "assumptions": "LLM-requested scopes are proposals and are not trusted authorization proofs.; Strict runtime surfaces consume LocalExecutionContext or gated facades.",
      "enforcement_terms": "request_envelope_valid, execution_scope_allowed, internal_policy_accept",
      "limitations": "Raw backend use outside the checked strict runtime kernel is outside the claim.",
      "property_id": "scope_non_escalation",
      "title": "Scope Non-Escalation"
    },
    {
      "assumptions": "A replay store with atomic reserve semantics is configured for strict runtime auth.; File and SQLite stores are local research backends; deployment needs a consistent shared backend.",
      "enforcement_terms": "request_envelope_valid, pq_signature_valid, can_accept, internal_policy_accept",
      "limitations": "The property is scoped to request-envelope digest consumption, not network-level packet replay.",
      "property_id": "replay_resistance",
      "title": "Replay Resistance"
    },
    {
      "assumptions": "Protected actions are reached only through the strict execution kernel.; Tests use side-effect counters or protected-action files as the oracle.",
      "enforcement_terms": "execution_scope_allowed, internal_policy_accept",
      "limitations": "The property does not cover unrelated application code that bypasses the kernel.",
      "property_id": "side_effect_free_rejection",
      "title": "Side-Effect-Free Rejection"
    }
  ],
